from telegram import Update
from telegram.ext import ContextTypes
from bot.database import get_conn, get_or_create_user
from bot.keyboards import debts_menu, main_menu, back_button

async def handle_debts(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    
    if query.data == "debts_menu":
        await query.edit_message_text(
            "💰 Qarzlar bo'limi:",
            reply_markup=debts_menu()
        )
    
    elif query.data == "debts_add":
        context.user_data['state'] = 'debt_name'
        await query.edit_message_text(
            "Mijoz ismini kiriting:",
            reply_markup=back_button()
        )
    
    elif query.data == "debts_list":
        user_id = get_or_create_user(
            update.effective_user.id,
            update.effective_user.full_name
        )
        conn = get_conn()
        c = conn.cursor()
        c.execute('''SELECT customer_name, amount, description 
                     FROM debts WHERE user_id = ? AND is_paid = 0''', (user_id,))
        debts = c.fetchall()
        conn.close()
        
        if not debts:
            text = "✅ Hech qanday qarzdor yo'q!"
        else:
            text = "💰 Qarzlar:\n\n"
            total = 0
            for d in debts:
                text += f"👤 {d[0]}: {d[1]:,.0f} so'm"
                if d[2]:
                    text += f" ({d[2]})"
                text += "\n"
                total += d[1]
            text += f"\n💵 Jami: {total:,.0f} so'm"
        
        await query.edit_message_text(text, reply_markup=back_button())
    
    elif query.data == "main_menu":
        await query.edit_message_text("Asosiy menyu:", reply_markup=main_menu())
